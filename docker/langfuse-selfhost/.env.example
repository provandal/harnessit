# HarnessIT — self-hosted Langfuse stack: env template.
#
# Copy this file to `.env` (gitignored) and replace every CHANGE_ME_* value
# before running `docker compose up`. The compose file uses `:?` substitutions
# so missing required vars will fail loudly at `up` time rather than silently
# starting an insecure stack.
#
# To generate strong secrets in one shot from a Bash shell:
#   POSTGRES_PASSWORD=$(openssl rand -hex 16)
#   CLICKHOUSE_PASSWORD=$(openssl rand -hex 16)
#   REDIS_AUTH=$(openssl rand -hex 16)
#   MINIO_ROOT_PASSWORD=$(openssl rand -hex 16)
#   SALT=$(openssl rand -hex 16)
#   ENCRYPTION_KEY=$(openssl rand -hex 32)        # MUST be exactly 64 hex chars
#   NEXTAUTH_SECRET=$(openssl rand -base64 32)
# Then write them into your real .env file.
#
# These secrets only need to protect against local processes on this machine —
# the dev stack binds every port to 127.0.0.1 except langfuse-web (3000). For
# any deployment more public than a laptop, harden further (TLS, real auth,
# managed secrets store).

# --- Required: storage layer credentials -------------------------------------

POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_POSTGRES_PASSWORD
POSTGRES_DB=postgres

CLICKHOUSE_USER=clickhouse
CLICKHOUSE_PASSWORD=CHANGE_ME_CLICKHOUSE_PASSWORD

REDIS_AUTH=CHANGE_ME_REDIS_AUTH

MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=CHANGE_ME_MINIO_ROOT_PASSWORD

# --- Required: Langfuse application secrets ----------------------------------

# SALT is mixed into hashed API keys. Treat as a credential.
SALT=CHANGE_ME_SALT

# ENCRYPTION_KEY encrypts secrets stored in Postgres (e.g. integration creds).
# MUST be exactly 64 hex chars. `openssl rand -hex 32` produces the right shape.
ENCRYPTION_KEY=CHANGE_ME_ENCRYPTION_KEY_64_HEX_CHARS_REQUIRED_PADDING_PADDING

# NEXTAUTH_SECRET signs Langfuse-web session cookies.
NEXTAUTH_SECRET=CHANGE_ME_NEXTAUTH_SECRET

# --- Optional: behavior knobs ------------------------------------------------

# Langfuse phones home anonymized usage telemetry by default. Off here because
# self-hosting is partly motivated by data ownership; flip to true if you want
# to contribute to upstream's stats.
TELEMETRY_ENABLED=false

# UI URL the Langfuse-web container reports to the browser. Change if you
# remap the host port below or front the stack with a reverse proxy.
NEXTAUTH_URL=http://localhost:3000

# Host port for the Langfuse UI. Change if 3000 conflicts on your machine.
LANGFUSE_WEB_PORT=3000

# --- Optional: headless first-run init ---------------------------------------
#
# If all of these are set, langfuse-web seeds the database with an org +
# project + user + API keys on first boot, so you never have to click through
# the sign-up wizard. Uncomment + fill in to use; leave commented to use the
# web sign-up flow.
#
# LANGFUSE_INIT_ORG_ID=harnessit
# LANGFUSE_INIT_ORG_NAME=HarnessIT
# LANGFUSE_INIT_PROJECT_ID=harnessit-local
# LANGFUSE_INIT_PROJECT_NAME=HarnessIT (self-hosted)
# LANGFUSE_INIT_PROJECT_PUBLIC_KEY=pk-lf-CHANGE_ME
# LANGFUSE_INIT_PROJECT_SECRET_KEY=sk-lf-CHANGE_ME
# LANGFUSE_INIT_USER_EMAIL=you@example.com
# LANGFUSE_INIT_USER_NAME=Erik
# LANGFUSE_INIT_USER_PASSWORD=CHANGE_ME_INITIAL_PASSWORD
